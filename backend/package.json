    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^4.1.5",
    "c8": "^11.0.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
