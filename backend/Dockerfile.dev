FROM node:20.19-alpine

WORKDIR /app

RUN npm install -g pnpm

COPY package.json pnpm-lock.yaml* ./

RUN pnpm install

COPY prisma ./prisma/
RUN pnpm prisma generate

COPY . .

RUN if [ ! -f .env ]; then cp .env.example .env 2>/dev/null || true; fi

EXPOSE 3001

CMD ["sh", "-c", "npx prisma migrate deploy && pnpm dev"]