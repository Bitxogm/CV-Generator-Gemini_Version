# ============================================
# CV Crafter - Variables de entorno (frontend)
# ============================================
#
# Instrucciones:
# 1) Copia este archivo a .env
#    cp .env.example .env
# 2) Rellena los valores
# 3) Reinicia el servidor Vite si ya estaba arrancado
#
# ⚠️ Importante:
# Variables VITE_* se exponen en el bundle cliente.
# No uses aquí secretos sensibles de producción.

# API Key de Google Gemini (obligatoria para funciones IA)
# Se usa en src/services/geminiService.ts
VITE_GEMINI_API_KEY=
