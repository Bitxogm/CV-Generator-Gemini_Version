{
  "name": "talenthub",
  "version": "1.0.0",
  "private": true,
  "description": "TalentHub - Marketplace de Perfiles Profesionales con IA",
  "author": "Victor Manuel González Moreno <vmmoreno1999@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "clean-ports": "bash scripts/kill-ports.sh",
    "dev": "concurrently -n \"POSTGRES,BACKEND,FRONTEND\" -c \"blue,green,cyan\" \"pnpm dev:postgres\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:postgres": "docker-compose -f docker-compose.dev.yml up postgres",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:parallel": "pnpm --parallel -r dev",
    "dev:all-docker": "docker-compose -f docker-compose.dev.yml up",
    "stop": "docker-compose -f docker-compose.dev.yml down",
    "clean": "docker-compose -f docker-compose.dev.yml down -v",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check-secrets": "node scripts/checksecrets.js",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up -d",
    "prisma:generate": "pnpm --filter backend prisma:generate",
    "prisma:migrate": "pnpm --filter backend prisma:migrate",
    "prisma:studio": "pnpm --filter backend prisma:studio",
    "prepare": "husky"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  }
}
